{
  "ConnectionStrings": {
    //Server tähendab andmebaasi serveri aadressi, mis võib olla kohalik (localdb) või kaugserver.
    //Database tähendab andmebaasi nime, mida soovite kasutada.
    //Trusted_Connection=True tähendab, et ühendus kasutab Windowsi autentimist ja kasutaja peab olema õigustega Windowsi kasutaja.
    //MultipleActiveResultSets=true võimaldab samaaegselt avada mitu andmebaasi päringut ja käsitleda nende tulemusi.
    "UniversityContext": "Server=(localdb)\\mssqllocaldb;Database=UniversityDB;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*"
}
